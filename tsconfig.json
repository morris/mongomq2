{
  "include": ["src", "test"],
  "compilerOptions": {
    "rootDir": ".",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "types": ["node"],

    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "nodenext",
    "sourceMap": true,
    "declaration": true,

    "strict": true,
    "noUnusedLocals": true,

    "noEmit": true
  }
}
